root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{xml,yml,yaml,conf,example}]
indent_style = space
indent_size = 2

[CODEOWNERS]
indent_style = space
indent_size = 2