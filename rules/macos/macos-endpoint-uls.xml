<group name="macos,endpoint,uls,">

  <rule id="100900" level="10">
    <program_name>sudo</program_name>
    <description>macOS endpoint: sudo activity observed</description>
  </rule>

  <rule id="100901" level="10">
    <program_name>sshd</program_name>
    <description>macOS endpoint: SSH activity observed</description>
  </rule>

  <rule id="100902" level="9">
    <program_name>sessionlogoutd</program_name>
    <match>logout is complete</match>
    <description>macOS endpoint: User logout completed</description>
  </rule>

  <rule id="100903" level="11">
    <program_name>tccd</program_name>
    <match>Update Access Record</match>
    <description>macOS endpoint: TCC access record updated</description>
  </rule>

  <rule id="100904" level="9">
    <match>SessionAgentNotificationCenter</match>
    <description>macOS endpoint: Session agent notification event observed</description>
  </rule>

  <rule id="100905" level="11">
    <program_name>screensharingd</program_name>
    <match>Authentication</match>
    <description>macOS endpoint: Screen sharing authentication activity observed</description>
  </rule>

  <rule id="100906" level="10">
    <program_name>securityd</program_name>
    <match>Session</match>
    <description>macOS endpoint: securityd session event observed</description>
  </rule>

  <rule id="100907" level="9">
    <program_name>loginwindow</program_name>
    <match>PersistentAppsSupport</match>
    <description>macOS endpoint: loginwindow persistence-related event observed</description>
  </rule>

  <rule id="100908" level="9">
    <program_name>launchservicesd</program_name>
    <match>CFBundleIdentifier</match>
    <description>macOS endpoint: LaunchServices application metadata event observed</description>
  </rule>

</group>