<group name="linux,cred_access,audit_keys,">

  <rule id="100610" level="7">
    <if_sid>80700</if_sid>
    <list field="audit.key" lookup="match_key_value" check_value="passwd">etc/lists/audit-keys</list>
    <description>Credential access: password file was accessed: $(audit.file.name)</description>
    <group>audit_command,</group>
    <mitre>
      <id>T1003.008</id>
    </mitre>
  </rule>

  <rule id="100611" level="10">
    <if_sid>80700</if_sid>
    <list field="audit.key" lookup="match_key_value" check_value="shadow">etc/lists/audit-keys</list>
    <description>Credential access: shadow file was accessed: $(audit.file.name)</description>
    <group>audit_command,</group>
    <mitre>
      <id>T1003.008</id>
    </mitre>
  </rule>

  <rule id="100612" level="5">
    <if_sid>80700</if_sid>
    <list field="audit.key" lookup="match_key_value" check_value="ssh">etc/lists/audit-keys</list>
    <description>Credential access: SSH-related file was accessed: $(audit.file.name)</description>
    <group>audit_command,</group>
  </rule>

  <rule id="100613" level="5">
    <if_sid>80700</if_sid>
    <list field="audit.key" lookup="match_key_value" check_value="history">etc/lists/audit-keys</list>
    <description>Credential access: shell history-related file was accessed: $(audit.file.name)</description>
    <group>audit_command,</group>
  </rule>

  <rule id="100614" level="7">
    <if_sid>80700</if_sid>
    <field name="audit.exe" type="pcre2">/usr/bin/.*grep</field>
    <field name="audit.execve.a2">cred|password|login</field>
    <description>Credential access: grep was used with credential-related search terms</description>
    <group>audit_command,</group>
  </rule>

</group>